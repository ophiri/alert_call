# =============================================================================
# Twilio Configuration
# Sign up at: https://www.twilio.com/
# Get credentials from: https://console.twilio.com/
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX  # Your Twilio phone number (with country code)

# =============================================================================
# Your Phone Number (the number that will receive the alert calls)
# Must include country code, e.g. +972501234567
# =============================================================================
MY_PHONE_NUMBER=+972XXXXXXXXX

# =============================================================================
# Service Settings
# =============================================================================
POLL_INTERVAL_SECONDS=2
ALERT_COOLDOWN_SECONDS=60

# =============================================================================
# Areas to Monitor (comma-separated, leave empty for ALL areas)
# Examples: תל אביב,רמת גן,גבעתיים
# =============================================================================
MONITORED_AREAS=תל אביב

# =============================================================================
# Custom Call Message (optional)
# Use {areas} as placeholder for the alert areas
# =============================================================================
# CALL_MESSAGE_TEMPLATE=אזהרה! התקבלה התרעה על ירי רקטות באזור {areas}. יש להיכנס למרחב המוגן מיד!

# =============================================================================
# Web Interface Settings
# =============================================================================
WEB_PASSWORD=your_password_here
WEB_SECRET_KEY=your_random_secret_key_here
# WEB_HOST=0.0.0.0
# WEB_PORT=8080
